package guiReplyManagement;

import javafx.geometry.Pos;
import javafx.scene.Scene;
import javafx.scene.control.*;
import javafx.scene.layout.Pane;
import javafx.scene.text.Font;
import javafx.stage.Stage;
import entityClasses.User;
import entityClasses.Reply;
import java.time.format.DateTimeFormatter;

public class ViewReplyList {
    private static double width = applicationMain.FoundationsMain.WINDOW_WIDTH;
    private static double height = applicationMain.FoundationsMain.WINDOW_HEIGHT;

    protected static ListView<String> list_Replies = new ListView<>();
    protected static TextArea area_ReplyBody = new TextArea();
    protected static Button button_Back = new Button("Back to Post");

    private static Pane theRootPane;
    private static Scene theScene;
    private static ViewReplyList theView;
    private static int currentPostId;

    public static void displayReplyList(Stage ps, User user, int postId) {
        currentPostId = postId;
        if (theView == null) theView = new ViewReplyList();
        
        refreshReplyList();
        ps.setScene(theScene);
        ps.setTitle("Viewing Replies");
        ps.show();
    }

    private ViewReplyList() {
        theRootPane = new Pane();
        theScene = new Scene(theRootPane, width, height);

        Label label_Title = new Label("Post Replies");
        label_Title.setFont(Font.font("Arial", 24));
        label_Title.setLayoutX(20); label_Title.setLayoutY(20);

        // Sidebar for replies
        list_Replies.setLayoutX(20); list_Replies.setLayoutY(70);
        list_Replies.setPrefSize(280, height - 150);
        
        // Main area to read the selected reply
        area_ReplyBody.setLayoutX(320); area_ReplyBody.setLayoutY(70);
        area_ReplyBody.setPrefSize(width - 350, height - 200);
        area_ReplyBody.setEditable(false);

        button_Back.setLayoutX(20); button_Back.setLayoutY(height - 60);
        button_Back.setOnAction((_) -> {
            guiPostManagement.ViewPostManagement.displayPostManagement(
                guiPostManagement.ViewPostManagement.theStage, 
                guiPostManagement.ViewPostManagement.theUser);
        });
        
        list_Replies.getSelectionModel().selectedItemProperty().addListener((_) -> {
            String selected = list_Replies.getSelectionModel().getSelectedItem();
            if (selected != null) {
                // Find the reply and set the text area to show the content
                // Assuming the selected string starts with "From: username"
                for (entityClasses.Reply r : ModelReplyManagement.getReplyStorage().getAllReplies()) {
                    // Simplified matching logic for the demo
                    area_ReplyBody.setText(r.getBody());
                }
            }
        });

        theRootPane.getChildren().addAll(label_Title, list_Replies, area_ReplyBody, button_Back);
    }

    public static void refreshReplyList() {
        list_Replies.getItems().clear();
        DateTimeFormatter formatter = DateTimeFormatter.ofPattern("MMM dd, hh:mm a");
        
        // Filter: Only show replies for THIS post
        for (Reply r : ModelReplyManagement.getReplyStorage().getRepliesForPost(currentPostId)) {
            list_Replies.getItems().add("From: " + r.getAuthor() + "\nAt: " + r.getTimestamp().format(formatter));
        }
    }
}