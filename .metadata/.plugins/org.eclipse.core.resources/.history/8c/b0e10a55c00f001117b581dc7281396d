package entityClasses;
import java.util.ArrayList;
import java.util.List;
import java.util.stream.Collectors;

/**
 * Manages storage and retrieval of Post objects.
 * Provides CRUD operations and collection-level validation.
 */
public class PostStorage {

    private final List<Post> posts;

    /**
     * Creates an empty PostStorage.
     */
    public PostStorage() {
        this.posts = new ArrayList<>();
    }

    /**
     * Adds a post to the collection.
     *
     * @param post the Post to add
     * @throws IllegalArgumentException if the post is null
     */
    public void addPost(Post post) {
        if (post == null) {
            throw new IllegalArgumentException("Cannot add a null post.");
        }
        posts.add(post);
    }

    /**
     * Retrieves all posts in the collection.
     * An empty list is returned if no posts exist.
     *
     * @return a list of all posts (may be empty)
     */
    public List<Post> getAllPosts() {
        return new ArrayList<>(posts);
    }

    /**
     * Retrieves a post by its unique ID.
     *
     * @param id the post ID
     * @return the Post with the given ID
     * @throws IllegalArgumentException if no post with the given ID exists
     */
    public Post getPostById(int id) {
        return posts.stream()
                .filter(p -> p.getId() == id)
                .findFirst()
                .orElseThrow(() ->
                        new IllegalArgumentException("Post with the given ID does not exist.")
                );
    }

    /**
     * Retrieves a subset of posts based on a filter string.
     * The filter is matched against the post title and body.
     *
     * @param filter the filter value (must not be null)
     * @return a list of posts matching the filter
     * @throws IllegalArgumentException if the filter is null
     */
    public List<Post> getPostsByFilter(String filter) {
        if (filter == null) {
            throw new IllegalArgumentException("Search filter cannot be null.");
        }

        return posts.stream()
                .filter(p ->
                        p.getTitle().toLowerCase().contains(filter.toLowerCase()) ||
                        p.getBody().toLowerCase().contains(filter.toLowerCase())
                )
                .collect(Collectors.toList());
    }

    /**
     * Removes a post from the collection by its ID.
     *
     * @param id the post ID
     * @throws IllegalArgumentException if no post with the given ID exists
     */
    public void removePostById(int id) {
        Post postToRemove = posts.stream()
                .filter(p -> p.getId() == id)
                .findFirst()
                .orElseThrow(() ->
                        new IllegalArgumentException("Cannot remove post that does not exist.")
                );

        posts.remove(postToRemove);
    }
    
