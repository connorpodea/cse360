package guiPostManagement;

import javafx.scene.control.Alert;
import javafx.scene.control.Alert.AlertType;

/*******
 * <p> Title: ControllerPostManagement Class. </p>
 * <p> Description: Controller for CRUD operations on Posts. </p>
 * <p> Copyright: Lynn Robert Carter © 2025 </p>
 */
public class ControllerPostManagement {

	protected static void performCreatePost() {
		int id = ModelPostManagement.getNextPostId();
		String title = ViewPostManagement.text_Title.getText();
		String body = ViewPostManagement.text_Body.getText();
		String author = ViewPostManagement.theUser.getUserName();

		// Validation Logic from User Stories
		if (title.isEmpty()) {
			showAlert("Validation Error", "Post title cannot be empty.");
			return;
		}
		if (title.length() > 200) {
			showAlert("Validation Error", "Post title exceeds maximum length.");
			return;
		}
		if (body.isEmpty()) {
			showAlert("Validation Error", "Post body cannot be empty.");
			return;
		}

		// If valid, tell the model to save it
		ModelPostManagement.createPost(id, title, body, author);
		showAlert("Success", "Post created successfully!");
		
		// Clear fields after success
		ViewPostManagement.text_Title.clear();
		ViewPostManagement.text_Body.clear();
	}

	protected static void performBack() {
		// Return to the home page (Role 2)
		guiRole2.ViewRole2Home.displayRole2Home(ViewPostManagement.theStage, ViewPostManagement.theUser);
	}

	private static void showAlert(String title, String message) {
		Alert alert = new Alert(AlertType.INFORMATION);
		alert.setTitle(title);
		alert.setHeaderText(null);
		alert.setContentText(message);
		alert.showAndWait();
	}
	
	// New method to handle transition to reply screen
	protected static void performReplyToSelected() {
        // Get the selected string from the list
        String selected = ViewPostManagement.list_Posts.getSelectionModel().getSelectedItem();
        
        if (selected == null) {
            // Error Message (Task 3 validation requirement)
            showAlert("Selection Error", "Please select a post from the list to reply.");
            return;
        }

        // Parse the ID out of the string (Assuming format "ID: Title")
        try {
            int postId = Integer.parseInt(selected.split(":")[0]);
            // Navigate to Reply View (Task 7.5 demo requirement)
            guiReplyManagement.ViewReplyManagement.displayReplyManagement(
                ViewPostManagement.theStage, ViewPostManagement.theUser, postId);
        } catch (Exception e) {
            showAlert("Error", "Could not parse Post ID.");
        }
    }
	
}