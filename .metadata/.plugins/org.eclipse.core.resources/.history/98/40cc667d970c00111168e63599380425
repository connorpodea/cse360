package guiReplyManagement;

import javafx.scene.control.Alert;
import javafx.scene.control.Alert.AlertType;

/*******
 * <p> Title: ControllerReplyManagement Class. </p>
 * <p> Description: Controller for CRUD operations on Replies. </p>
 * <p> Copyright: Lynn Robert Carter © 2025 </p>
 */
public class ControllerReplyManagement {

	protected static void performCreateReply() {
		String body = ViewReplyManagement.text_Body.getText();
		String author = ViewReplyManagement.theUser.getUserName();
		long parentPostId = ViewReplyManagement.currentPostId;

		// Validation Logic from Task 2 User Stories
		if (body.isEmpty()) {
			showAlert("Validation Error", "Reply body cannot be empty.");
			return;
		}
		
		// Logic to ensure the parent post still exists (Task 3 Negative Test)
		if (parentPostId <= 0) {
			showAlert("Validation Error", "Cannot reply to a post that does not exist.");
			return;
		}

		// Generate unique ID and save
		long id = ModelReplyManagement.getNextReplyId();
		ModelReplyManagement.createReply(id, parentPostId, body, author);
		
		showAlert("Success", "Reply added with ID: " + id);
		ViewReplyManagement.text_Body.clear();
	}

	protected static void performBack() {
		// Navigation back to the specific post view or home
		guiRole2.ViewRole2Home.displayRole2Home(ViewReplyManagement.theStage, ViewReplyManagement.theUser);
	}

	private static void showAlert(String title, String message) {
		Alert alert = new Alert(AlertType.INFORMATION);
		alert.setTitle(title);
		alert.setHeaderText(null);
		alert.setContentText(message);
		alert.showAndWait();
	}
}