import java.util.ArrayList;
import java.util.List;
import java.util.stream.Collectors;
import Reply.java;

/**
 * Stores and manages all Reply objects.
 * Supports CRUD operations and subset retrieval with validation.
 */
public class ReplyStorage {

    private List<Reply> replies;

    /**
     * Creates a new ReplyStorage with an empty reply list.
     */
    public ReplyStorage() {
        this.replies = new ArrayList<>();
    }

    /**
     * Adds a reply to the storage.
     *
     * @param reply the reply to add
     * @throws IllegalArgumentException if reply is null
     */
    public void addReply(Reply reply) {
        if (reply == null) {
            throw new IllegalArgumentException("Cannot add a null reply.");
        }
        replies.add(reply);
    }

    /**
     * Retrieves a reply by its unique ID.
     *
     * @param id the reply ID
     * @return the Reply if found
     * @throws IllegalArgumentException if the reply does not exist
     */
    public Reply getReplyById(int id) {
        return replies.stream()
                .filter(r -> r.getId() == id)
                .findFirst()
                .orElseThrow(() ->
                        new IllegalArgumentException("Reply with the given ID does not exist.")
                );
    }

    /**
     * Updates the body of an existing reply.
     *
     * @param id      the reply ID
     * @param newBody the updated body text
     * @throws IllegalArgumentException if the reply does not exist or body is invalid
     */
    public void updateReply(int id, String newBody) {
        Reply reply = replies.stream()
                .filter(r -> r.getId() == id)
                .findFirst()
                .orElseThrow(() ->
                        new IllegalArgumentException("Cannot update a reply that does not exist.")
                );

        reply.update(newBody);
    }

    /**
     * Deletes a reply by its ID.
     *
     * @param id the reply ID
     * @throws IllegalArgumentException if the reply does not exist
     */
    public void deleteReply(int id) {
        Reply reply = replies.stream()
                .filter(r -> r.getId() == id)
                .findFirst()
                .orElseThrow(() ->
                        new IllegalArgumentException("Cannot delete reply because it does not exist.")
                );

        replies.remove(reply);
    }

    /**
     * Retrieves all replies for a given post ID.
     *
     * @param postId the post ID
     * @param postStorage the post storage to validate the post exists
     * @return list of replies belonging to the post
     * @throws IllegalArgumentException if the post does not exist
     */
    public List<Reply> getRepliesForPost(int postId, PostStorage postStorage) {
        if (!postStorage.exists(postId)) {
            throw new IllegalArgumentException("Cannot retrieve replies for a post that does not exist.");
        }

        return replies.stream()
                .filter(r -> r.getPostId() == postId)
                .collect(Collectors.toList());
    }

    /**
     * Retrieves a subset of replies using a filter string.
     *
     * @param filter the filter keyword
     * @return subset of replies matching the filter
     * @throws IllegalArgumentException if filter is null
     */
    public List<Reply> getRepliesByFilter(String filter) {
        if (filter == null) {
            throw new IllegalArgumentException("Search filter cannot be null.");
        }

        return replies.stream()
                .filter(r -> r.getBody().toLowerCase().contains(filter.toLowerCase()))
                .collect(Collectors.toList());
    }

    /**
     * Returns all stored replies.
     *
     * @return list of all replies
     */
    public List<Reply> getAllReplies() {
        return new ArrayList<>(replies);
    }

    /**
     * Checks if a reply with the given ID exists.
     *
     * @param id the reply ID
     * @return true if reply exists, false otherwise
     */
    public boolean exists(int id) {
        return replies.stream().anyMatch(r -> r.getId() == id);
    }
}
